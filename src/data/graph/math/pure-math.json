      "prerequisites": ["differential-geometry", "manifolds"]
    },
    {
      "id": "algebraic-geometry",
      "label": "代数幾何学",
      "area": "pure_geometry",
      "difficulty": 5,
      "position": { "x": 2000, "y": 280 },
      "description": "多項式の零点集合の幾何学。可換代数との深い結びつき。",
      "prerequisites": ["commutative-algebra", "point-set-topology"]
    },
    {
      "id": "prime-numbers",
      "label": "素数",
      "area": "pure_algebra",
      "difficulty": 2,
      "position": { "x": 1000, "y": 320 },
