{
  "nodes": [
    {
      "id": "linear-algebra",
      "label": "線形代数",
      "area": "pure_algebra",
      "difficulty": 3,
      "position": { "x": 1000, "y": 40 },
      "description": "ベクトル・行列・線形変換。現代数学の基本言語。",
      "prerequisites": ["functions", "real-numbers"]
    },
    {
      "id": "group-theory",
      "label": "群論",
      "area": "pure_algebra",
      "difficulty": 3,
      "position": { "x": 1250, "y": 40 },
      "description": "対称性を抽象化した代数構造。",
      "prerequisites": ["linear-algebra", "proof-methods"]
    },
    {
      "id": "number-theory",
      "label": "初等整数論",
      "area": "pure_algebra",
      "difficulty": 3,
      "position": { "x": 1250, "y": 320 },
      "description": "合同式・二次剰余。整数の深い性質。",
      "prerequisites": ["prime-numbers", "proof-methods"]
    },
    {
      "id": "ring-theory",
      "label": "環論",
      "area": "pure_algebra",
      "difficulty": 4,
      "position": { "x": 1500, "y": 0 },
      "description": "環・イデアル・剰余環。加法と乗法を持つ代数構造。",
      "prerequisites": ["group-theory", "linear-algebra"]
    },
    {
      "id": "field-theory",
      "label": "体論",
      "area": "pure_algebra",
      "difficulty": 4,
      "position": { "x": 1750, "y": -80 },
      "description": "体の拡大・分離拡大。方程式の可解性への道。",
      "prerequisites": ["ring-theory"]
    },
    {
      "id": "galois-theory",
      "label": "ガロア理論",
      "area": "pure_algebra",
      "difficulty": 5,
      "position": { "x": 2000, "y": -80 },
      "description": "体の拡大と群の対応。方程式の可解性の完全な解答。",
      "prerequisites": ["field-theory", "group-theory"]
    },
    {
      "id": "module-theory",
      "label": "加群論",
      "area": "pure_algebra",
      "difficulty": 4,
      "position": { "x": 1500, "y": 120 },
      "description": "環上の加群。線形代数の一般化。",
      "prerequisites": ["ring-theory", "linear-algebra"]
    },
    {
      "id": "commutative-algebra",
      "label": "可換代数",
      "area": "pure_algebra",
      "difficulty": 5,
      "position": { "x": 1750, "y": 40 },
      "description": "可換環とその加群。代数幾何の代数的基盤。",
      "prerequisites": ["ring-theory", "module-theory"]
    },
    {
      "id": "homological-algebra",
      "label": "ホモロジー代数",
      "area": "pure_algebra",
      "difficulty": 5,
      "position": { "x": 2000, "y": 120 },
      "description": "完全系列・導来関手。代数の深い構造論。",
      "prerequisites": ["module-theory", "category-theory"]
    },
    {
      "id": "representation-theory",
      "label": "表現論",
      "area": "pure_algebra",
      "difficulty": 5,
      "position": { "x": 2000, "y": 240 },
      "description": "群や環を行列で表現する理論。",
      "prerequisites": ["group-theory", "linear-algebra", "module-theory"]
    },
    {
      "id": "algebraic-number-theory",
      "label": "代数的整数論",
      "area": "pure_algebra",
      "difficulty": 5,
      "position": { "x": 2000, "y": 320 },
      "description": "代数体の整数環。フェルマー予想への道。",
      "prerequisites": ["number-theory", "field-theory"]
    },
    {
      "id": "lie-algebras",
      "label": "リー代数",
      "area": "pure_algebra",
      "difficulty": 5,
      "position": { "x": 1750, "y": 240 },
      "description": "連続対称性の無限小構造。微分幾何・物理への橋。",
      "prerequisites": ["linear-algebra", "group-theory"]
    },
    {
      "id": "calculus-differential",
      "label": "微分",
      "area": "pure_analysis",
      "difficulty": 3,
      "position": { "x": 1000, "y": -200 },
      "description": "変化の速さを捉える。極限・導関数。",
      "prerequisites": ["real-numbers", "functions"]
    },
    {
      "id": "calculus-integral",
      "label": "積分",
      "area": "pure_analysis",
      "difficulty": 3,
      "position": { "x": 1250, "y": -200 },
      "description": "面積・累積量を求める。不定積分と定積分。",
      "prerequisites": ["calculus-differential"]
    },
    {
      "id": "multivariable-calculus",
      "label": "多変数微積分",
      "area": "pure_analysis",
      "difficulty": 3,
      "position": { "x": 1500, "y": -280 },
      "description": "偏微分・重積分・ベクトル解析。多次元への拡張。",
      "prerequisites": ["calculus-integral", "linear-algebra"]
    },
    {
      "id": "sequences-series",
      "label": "級数論",
      "area": "pure_analysis",
      "difficulty": 3,
      "position": { "x": 1500, "y": -160 },
      "description": "数列・級数の収束。テイラー展開・べき級数。",
      "prerequisites": ["calculus-integral"]
    },
    {
      "id": "ode",
      "label": "常微分方程式",
      "area": "pure_analysis",
      "difficulty": 3,
      "position": { "x": 1750, "y": -280 },
      "description": "未知関数とその導関数の方程式。",
      "prerequisites": ["multivariable-calculus"]
    },
    {
      "id": "real-analysis",
      "label": "実解析",
      "area": "pure_analysis",
      "difficulty": 4,
      "position": { "x": 1750, "y": -160 },
      "description": "厳密なε-δ論法。位相的性質と収束の理論。",
      "prerequisites": ["sequences-series", "proof-methods"]
    },
    {
      "id": "complex-analysis",
      "label": "複素解析",
      "area": "pure_analysis",
      "difficulty": 4,
      "position": { "x": 1750, "y": -40 },
      "description": "正則関数・コーシーの積分定理・留数。",
      "prerequisites": ["multivariable-calculus", "complex-numbers"]
    },
    {
      "id": "measure-theory",
      "label": "測度論",
      "area": "pure_analysis",
      "difficulty": 4,
      "position": { "x": 2000, "y": -160 },
      "description": "ルベーグ測度・ルベーグ積分。現代解析の基礎。",
      "prerequisites": ["real-analysis"]
    },
    {
      "id": "pde",
      "label": "偏微分方程式",
      "area": "pure_analysis",
      "difficulty": 4,
      "position": { "x": 2000, "y": -280 },
      "description": "多変数の微分方程式。物理現象のモデル化。",
      "prerequisites": ["ode", "multivariable-calculus"]
    },
    {
      "id": "functional-analysis",
      "label": "関数解析",
      "area": "pure_analysis",
      "difficulty": 5,
      "position": { "x": 2250, "y": -160 },
      "description": "バナッハ空間・ヒルベルト空間。無限次元の線形代数。",
      "prerequisites": ["measure-theory", "linear-algebra"]
    },
    {
      "id": "fourier-analysis",
      "label": "フーリエ解析",
      "area": "pure_analysis",
      "difficulty": 4,
      "position": { "x": 2000, "y": -40 },
      "description": "フーリエ級数・フーリエ変換。信号分解の数学。",
      "prerequisites": ["complex-analysis", "real-analysis"]
    },
    {
      "id": "harmonic-analysis",
      "label": "調和解析",
      "area": "pure_analysis",
      "difficulty": 5,
      "position": { "x": 2250, "y": -40 },
      "description": "フーリエ解析の一般化。群上の解析。",
      "prerequisites": ["fourier-analysis", "functional-analysis"]
    },
    {
      "id": "operator-theory",
      "label": "作用素論",
      "area": "pure_analysis",
      "difficulty": 5,
      "position": { "x": 2250, "y": -280 },
      "description": "線形作用素のスペクトル理論。量子力学の数学的基盤。",
      "prerequisites": ["functional-analysis"]
    },
    {
      "id": "euclidean-geometry",
      "label": "ユークリッド幾何",
      "area": "pure_geometry",
      "difficulty": 2,
      "position": { "x": 1000, "y": 200 },
